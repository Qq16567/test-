import random
matrix = [[random.randint(1, 10) for _ in range(4)] for _ in range(3)]
print("Исходная матрица:")
for row in matrix: print(row)

total_sum = 0
max_row_sum = -1
max_row_idx = 0

print("\nРезультаты:")
for i, row in enumerate(matrix):
    row_sum = sum(row)
    total_sum += row_sum
    print(f"Сумма строки {i}: {row_sum}")

    if row_sum > max_row_sum:
        max_row_sum = row_sum
        max_row_idx = i

print(f"\nОбщая сумма всех элементов: {total_sum}")
print(f"Строка с максимальной суммой: индекс {max_row_idx} (сумма: {max_row_sum})")
